# .gitworktreecopy
# Files/dirs to copy or symlink from main worktree to new worktrees
#
# Syntax:
#   pattern        — copy matching files
#   ~> pattern     — symlink instead of copy
#   **/*.ext       — glob for recursive matching
#   # comment      — ignored
#
# Symlink heavy dirs to save disk space and install time:
~> node_modules

# Environment files (not in git)
**/*.env
**/*.env.local

# Local data directories
~> data

