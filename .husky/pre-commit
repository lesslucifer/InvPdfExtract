#!/usr/bin/env sh

if [ -f "$(dirname -- "$0")/_/.env" ]; then
  . "$(dirname -- "$0")/_/.env"
  export PATH="${PATH}:${EXT_PATH}"
fi

echo "Running checks in parallel: tsc, lint, test"

pnpm tsc &
PID_TSC=$!
pnpm lint &
PID_LINT=$!
pnpm test &
PID_TEST=$!

FAILED=()

wait $PID_TSC || FAILED+=("tsc")
wait $PID_LINT || FAILED+=("lint")
wait $PID_TEST || FAILED+=("test")

if [ ${#FAILED[@]} -gt 0 ]; then
  echo "Failed checks: ${FAILED[*]}"
  exit 1
fi
